{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 19,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "indigo-debug",
            "displayName": "Indigo Build debug",
            "description": "Configure Indigo with wrappers and utils enabled",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "BUILD_INDIGO": "ON",
                "BUILD_INDIGO_WRAPPERS": "ON",
                "BUILD_INDIGO_UTILS": "ON",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "indigo-all-debug",
            "configurePreset": "indigo-debug",
            "displayName": "Build Indigo DEBUG (Linux All Targets)",
            "description": "Build all targets",
            "targets": [
                "all"
            ]
        }
    ]
}
